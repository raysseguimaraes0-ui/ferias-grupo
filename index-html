// helpers
function getEmps(){return session.accessEmpresa==='grupo'?Object.keys(COS):[session.accessEmpresa];}
function ini(n){return n.split(' ').filter(Boolean).slice(0,2).map(x=>x[0]).join('').toUpperCase();}
function fd(d){if(!d)return'—';const[y,m,day]=d.split('-');return`${day}/${m}/${y}`;}
function diasEntre(ini,fim){
  if(!ini||!fim)return 0;
  const [yi,mi,di]=ini.split('-').map(Number),[yf,mf,df]=fim.split('-').map(Number);
  const start=new Date(yi,mi-1,di),end=new Date(yf,mf-1,df);
  const dias=Math.round((end-start)/(1000*60*60*24))+1;
  return dias>0?dias:0;
}
function diasGozo(g){return g&&g.ini&&g.fim?diasEntre(g.ini,g.fim):0;}
function toast(msg){const t=document.getElementById('toast');t.textContent=msg;t.classList.add('show');setTimeout(()=>t.classList.remove('show'),2800);}
function emp2Main(e){
  // Retorna o gozo principal (maior status priority: em-ferias > aprovado > planejado)
  const allGozos=e.periodos.flatMap(p=>p.gozados.filter(g=>g.ini));
  const order={aprovado:3,'em-ferias':4,planejado:2,recusado:1};
  if(!allGozos.length)return null;
  return allGozos.sort((a,b)=>(order[b.status]||0)-(order[a.status]||0))[0];
}
function saldoPendente(e){return e.periodos.filter(p=>!p.isCurrent&&calcSaldo(p)>0).reduce((s,p)=>s+calcSaldo(p),0);}
function calcSaldo(p){const g=p.gozados.reduce((s,x)=>s+diasGozo(x),0);return Math.max(0,p.direito-g);}
function ensureSaldo(p){p.saldo=calcSaldo(p);}

