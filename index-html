      <table><thead><tr><th>Empresa</th><th>Funcionários</th><th>Com férias</th><th>Dias aprovados</th><th>Saldo anterior</th><th style="text-align:right">Custo est.</th></tr></thead>
      <tbody>${empList.map(k=>{
        const c=COS[k],emps=employees.filter(e=>e.empresa===k);
        emps.forEach(e=>e.periodos.forEach(p=>ensureSaldo(p)));
