        <div style="margin-top:12px;display:flex;gap:10px"><span style="font-size:10px;color:var(--text3);display:flex;align-items:center;gap:4px"><span style="width:10px;height:10px;border-radius:3px;background:#DBEAFE;display:inline-block"></span>1 pessoa</span><span style="font-size:10px;color:var(--text3);display:flex;align-items:center;gap:4px"><span style="width:10px;height:10px;border-radius:3px;background:#93C5FD;display:inline-block"></span>2+</span></div>
