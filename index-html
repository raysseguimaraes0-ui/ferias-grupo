// Calendário
function renderCalWidget(empresa){
  const el=document.getElementById('cal'),nmEl=document.getElementById('calMonthName');
  if(!el||!nmEl)return;
  const MN=['Janeiro','Fevereiro','Março','Abril','Maio','Junho','Julho','Agosto','Setembro','Outubro','Novembro','Dezembro'];
  nmEl.textContent=`${MN[calMonth]} ${calYear}`;
  const firstDay=new Date(calYear,calMonth,1).getDay(),daysInMonth=new Date(calYear,calMonth+1,0).getDate();
  const today=new Date(),isToday=d=>today.getFullYear()===calYear&&today.getMonth()===calMonth&&today.getDate()===d;
  const fmap={};
  employees.filter(e=>empresa?e.empresa===empresa:true).forEach(e=>{
    e.periodos.forEach(p=>p.gozados.forEach(g=>{
      if(!g.ini)return;
      const s=new Date(g.ini),f=new Date(g.fim);
      for(let d=new Date(s);d<=f;d.setDate(d.getDate()+1)){
        if(d.getFullYear()===calYear&&d.getMonth()===calMonth){const k=d.getDate();fmap[k]=(fmap[k]||0)+1;}
      }
    }));
  });
  let html='<div class="cal-grid">';
  ['D','S','T','Q','Q','S','S'].forEach(d=>html+=`<div class="cal-dn">${d}</div>`);
  for(let i=0;i<firstDay;i++)html+=`<div class="cal-d other"></div>`;
  for(let d=1;d<=daysInMonth;d++){
    const cnt=fmap[d]||0;let cls='cal-d';
    if(isToday(d))cls+=' today';else if(cnt>=2)cls+=' f2';else if(cnt>=1)cls+=' f1';
    html+=`<div class="${cls}" title="${cnt?cnt+' pessoa(s)':''}">${d}</div>`;
  }
  html+='</div>';el.innerHTML=html;
}
function calPrev(){calMonth--;if(calMonth<0){calMonth=11;calYear--;}renderCalWidget(currentEmpresa);}
function calNext(){calMonth++;if(calMonth>11){calMonth=0;calYear++;}renderCalWidget(currentEmpresa);}

