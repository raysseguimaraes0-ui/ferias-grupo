      }).join('')}</tbody></table>
    </div>`;
}

// Diretoria
function renderDiretoria(){
  if(session.role!=='diretoria'){document.getElementById('mainContent').innerHTML=`<div class="alert warn">Acesso restrito à Diretoria.</div>`;return;}
  const empList=getEmps(),all=employees;
  all.forEach(e=>e.periodos.forEach(p=>ensureSaldo(p)));
  const oficiais=all.filter(e=>{const g=emp2Main(e);return g&&e.oficial;});
  const extras=all.filter(e=>{const g=emp2Main(e);return g&&!e.oficial;});
  // Também mostra extra-oficiais que estão nas observações
  const comExtraObs=all.filter(e=>e.periodos.some(p=>p.gozados.some(g=>g.extraOficial)));

  document.getElementById('mainContent').innerHTML=`
    <div class="mrow">
      ${mcard('Colaboradores',all.length,'Total','#0f2942')}
      ${mcard('Férias aprovadas',all.filter(e=>{const g=emp2Main(e);return g&&g.status==='aprovado';}).length,'Confirmadas','#15803D')}
      ${mcard('Extra-oficiais',comExtraObs.length,'Funcionários c/ registro','#EA580C')}
      ${mcard('Saldo em aberto',all.filter(e=>saldoPendente(e)>0).length,'Períodos anteriores','#DC2626')}
    </div>
    <div style="font-size:13px;font-weight:700;color:var(--navy);margin:0 0 10px;display:flex;align-items:center;gap:8px">
      <span style="background:#DCFCE7;color:#15803D;padding:2px 10px;border-radius:99px;font-size:10px">OFICIAIS</span>Férias Oficiais
    </div>
    <div class="card cp" style="margin-bottom:20px">${dirTbl(oficiais,true)}</div>
    <div style="font-size:13px;font-weight:700;color:var(--navy);margin:0 0 10px;display:flex;align-items:center;gap:8px">
      <span style="background:#FFF7ED;color:#9A3412;padding:2px 10px;border-radius:99px;font-size:10px">EXTRA-OFICIAIS</span>Registros Extra-oficiais (observações)
    </div>
    <div class="card cp" style="margin-bottom:20px">
      ${renderExtraOficiais(comExtraObs)}
    </div>
    <div class="card cp"><div class="ch"><span class="ct">Consolidado</span><span class="atag dir">Diretoria</span></div>
      <table><thead><tr><th>Empresa</th><th>Total</th><th>Aprovadas</th><th>Extra-oficiais</th><th>Saldo ant.</th><th>Data limite mais próxima</th></tr></thead>
      <tbody>${empList.map(k=>{
        const c=COS[k],emps=employees.filter(e=>e.empresa===k);
        emps.forEach(e=>e.periodos.forEach(p=>ensureSaldo(p)));
        const sa=emps.reduce((s,e)=>s+saldoPendente(e),0);
        const eo=emps.filter(e=>e.periodos.some(p=>p.gozados.some(g=>g.extraOficial))).length;
        return`<tr><td><strong style="color:${c.color}">${c.name}</strong></td><td>${emps.length}</td>
          <td style="color:#15803D;font-weight:600">${emps.filter(e=>{const g=emp2Main(e);return g&&(g.status==='aprovado'||g.status==='em-ferias');}).length}</td>
          <td style="color:#EA580C;font-weight:600">${eo}</td>
          <td style="color:${sa>0?'#DC2626':'#15803D'};font-weight:700">${sa}d</td>
          <td style="font-size:11px;color:var(--text3)">${emps.filter(e=>e.periodos.some(p=>!p.isCurrent&&p.saldo>0&&p.dataLimite)).map(e=>e.periodos.filter(p=>!p.isCurrent&&p.saldo>0&&p.dataLimite).map(p=>`${e.name.split(' ')[0]}: ${p.dataLimite}`).join(', ')).join('<br>')||'—'}</td>
        </tr>`;
      }).join('')}</tbody></table>
    </div>`;
}

function renderExtraOficiais(data){
  if(!data.length)return`<div class="empty"><svg fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>Nenhum registro extra-oficial</div>`;
  return`<table><thead><tr><th>Funcionário</th><th>Empresa</th><th>Período aquisitivo</th><th>Observação / Registro</th><th>Ação</th></tr></thead><tbody>
  ${data.map((e,i)=>{
    const bg=avBg[i%avBg.length],tc=avTc[i%avTc.length],c=COS[e.empresa];
    const rows=e.periodos.flatMap(p=>p.gozados.filter(g=>g.extraOficial).map(g=>({label:p.label,g})));
    return rows.map(r=>`<tr>
      <td><div class="ec"><div class="av" style="background:${bg};color:${tc}">${ini(e.name)}</div><div><div class="en">${e.name}</div><div class="es">${e.cargo}</div></div></div></td>
      <td><span style="font-size:11px;font-weight:600;color:${c.color}">${c.name}</span></td>
      <td><span class="tag ant">${r.label}</span></td>
      <td style="font-size:11.5px;max-width:260px"><span class="obs-chip" style="max-width:100%;white-space:normal" title="${r.g.obs}">${r.g.obs||'Extra-oficial registrado'}</span></td>
      <td><button class="ab edt" onclick="openEditModal(${e.id})"><svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>Editar</button></td>
    </tr>`).join('');
  }).join('')}</tbody></table>`;
}

function dirTbl(data,isOf){
  if(!data.length)return`<div class="empty"><svg fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>Nenhum registro</div>`;
  const bl={aprovado:'Aprovado',pendente:'Pendente','em-ferias':'Em férias',recusado:'Recusado',planejado:'Planejado'};
  return`<table><thead><tr><th>Funcionário</th><th>Empresa</th><th>Período</th><th>Dias</th><th>Status</th><th>Tipo</th><th>Obs Diretoria</th><th>Ação</th></tr></thead><tbody>
  ${data.map((e,i)=>{const bg=avBg[i%avBg.length],tc=avTc[i%avTc.length],c=COS[e.empresa],g=emp2Main(e);return`<tr>
    <td><div class="ec"><div class="av" style="background:${bg};color:${tc}">${ini(e.name)}</div><div><div class="en">${e.name}</div><div class="es">${e.cargo}</div></div></div></td>
    <td><span style="font-size:11px;font-weight:600;color:${c.color}">${c.name}</span></td>
    <td style="font-size:11.5px">${g&&g.ini?fd(g.ini)+' → '+fd(g.fim):'—'}</td>
    <td>${g?`<span class="dp">${g.dias}d</span>`:'—'}</td>
    <td>${g?`<span class="badge ${g.status}">${bl[g.status]}</span>`:'—'}</td>
    <td><span class="tag ${isOf?'of':'extra'}">${isOf?'Oficial':'Extra-oficial'}</span></td>
    <td style="font-size:11px;color:var(--text3);font-style:italic;max-width:130px;overflow:hidden;text-overflow:ellipsis">${e.obsDir||'—'}</td>
    <td><button class="ab edt" onclick="openEditModal(${e.id})"><svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>Editar</button></td>
  </tr>`;}).join('')}</tbody></table>`;
}

// ===== MODAL =====
function openNewModal(){
  editingId=null;
  document.getElementById('modalTitle').textContent='Nova solicitação';
  document.getElementById('modalSub').textContent='Preencha os dados';
  document.getElementById('btnDel').style.display='none';
  document.getElementById('dirFields').style.display=session.role==='diretoria'?'':'none';
  ['mIni','mFim','mObs','mObsDir'].forEach(id=>{const el=document.getElementById(id);if(el)el.value='';});
  document.getElementById('mDias').value='';document.getElementById('mDAq').value='';
  document.getElementById('mStatus').value='planejado';
  if(document.getElementById('mOficial'))document.getElementById('mOficial').checked=true;
  const empList=getEmps(),sel=document.getElementById('mEmp');
  sel.innerHTML='<option value="">Selecione...</option>';
  empList.forEach(k=>sel.innerHTML+=`<option value="${k}">${COS[k].name}</option>`);
  document.getElementById('mFunc').innerHTML='<option value="">— selecione a empresa —</option>';
  document.getElementById('mPAq').innerHTML='<option value="">Selecione o funcionário</option>';
  document.getElementById('saldoInfoBox').style.display='none';
  document.getElementById('modalEdit').classList.add('open');
}

function openEditModal(id){
  const e=employees.find(x=>x.id===id);if(!e)return;
  editingId=id;
  document.getElementById('modalTitle').textContent=`Editar · ${e.name.split(' ')[0]}`;
  document.getElementById('modalSub').textContent=`${e.cargo} · ${COS[e.empresa].name}`;
  document.getElementById('btnDel').style.display='';
  document.getElementById('dirFields').style.display=session.role==='diretoria'?'':'none';
  const empList=getEmps(),selEmp=document.getElementById('mEmp');
  selEmp.innerHTML='<option value="">Selecione...</option>';
  empList.forEach(k=>selEmp.innerHTML+=`<option value="${k}">${COS[k].name}</option>`);
  selEmp.value=e.empresa;fillFuncs();
  setTimeout(()=>{document.getElementById('mFunc').value=e.id;fillPeriodos();},30);
  const g=emp2Main(e);
  document.getElementById('mIni').value=g?g.ini||'':'';
  document.getElementById('mFim').value=g?g.fim||'':'';
  document.getElementById('mDias').value=g?g.dias||'':'';
  document.getElementById('mStatus').value=g?g.status:'planejado';
  document.getElementById('mObs').value=g?g.obs||'':'';
  if(session.role==='diretoria'){
    document.getElementById('mOficial').checked=e.oficial!==false;
    document.getElementById('mObsDir').value=e.obsDir||'';
  }
  document.getElementById('modalEdit').classList.add('open');
}

function fillFuncs(){
  const k=document.getElementById('mEmp').value,sel=document.getElementById('mFunc');
  if(!k){sel.innerHTML='<option>— selecione a empresa —</option>';return;}
  sel.innerHTML='<option value="">Selecione...</option>'+employees.filter(e=>e.empresa===k).map(e=>`<option value="${e.id}">${e.name}</option>`).join('');
}

function fillPeriodos(){
  const empId=parseInt(document.getElementById('mFunc').value)||editingId;
  const e=employees.find(x=>x.id===empId);
  const sel=document.getElementById('mPAq');
  if(!e){sel.innerHTML='<option value="">Selecione o funcionário</option>';return;}
  e.periodos.forEach(p=>ensureSaldo(p));
  sel.innerHTML='<option value="">Selecione o período...</option>';
  e.periodos.forEach(p=>{
    const goz=p.gozados.reduce((s,g)=>s+diasGozo(g),0);
    const opt=document.createElement('option');opt.value=p.anoInicio;
    opt.textContent=`${p.label} · Saldo: ${p.saldo}d ${p.isCurrent?'(atual)':p.saldo>0?'⚠ PENDENTE':'✓ Quitado'}`;
    sel.appendChild(opt);
  });
  const ant=e.periodos.find(p=>!p.isCurrent&&p.saldo>0);
  if(ant)sel.value=ant.anoInicio;else{const c=e.periodos.find(p=>p.isCurrent);if(c)sel.value=c.anoInicio;}
  showSaldoInfo();
}

function showSaldoInfo(){
  const empId=parseInt(document.getElementById('mFunc').value)||editingId;
  const e=employees.find(x=>x.id===empId);
  const anoSel=parseInt(document.getElementById('mPAq').value);
  const box=document.getElementById('saldoInfoBox');
  if(!e||!anoSel){box.style.display='none';return;}
  const p=e.periodos.find(x=>x.anoInicio===anoSel);if(!p){box.style.display='none';return;}
  ensureSaldo(p);
  const goz=p.gozados.reduce((s,g)=>s+diasGozo(g),0);
  box.style.display='block';
  box.innerHTML=`<strong>Período ${p.label}</strong> · Direito: ${p.direito}d · Gozado: ${goz}d · <span style="color:${p.saldo>0?'#DC2626':'#15803D'};font-weight:700">${p.saldo}d de saldo restante</span>${p.dataLimite?` · Limite: <strong>${p.dataLimite}</strong>`:''}`;
  document.getElementById('mDAq').value=p.saldo>0?p.saldo:'';
}

function calcDias(){
  const ini=document.getElementById('mIni').value,fim=document.getElementById('mFim').value;
  if(ini&&fim){const d=Math.round((new Date(fim)-new Date(ini))/(1000*60*60*24))+1;if(d>0)document.getElementById('mDias').value=d;}
}

function closeModal(){document.getElementById('modalEdit').classList.remove('open');editingId=null;}

function saveModal(){
  const empId=parseInt(document.getElementById('mFunc').value)||editingId;
  if(!empId){toast('⚠ Selecione um funcionário');return;}
  const e=employees.find(x=>x.id===empId);if(!e)return;
  const iniV=document.getElementById('mIni').value,fimV=document.getElementById('mFim').value;
  let dias=parseInt(document.getElementById('mDias').value)||0;
  if(iniV&&fimV&&!dias)dias=Math.round((new Date(fimV)-new Date(iniV))/(1000*60*60*24))+1;
  const status=document.getElementById('mStatus').value;
  const obs=document.getElementById('mObs').value;
  const anoAq=parseInt(document.getElementById('mPAq').value);
  const diasAq=parseInt(document.getElementById('mDAq').value)||dias;
  // Atualiza o período selecionado
  if(anoAq){
    const p=e.periodos.find(x=>x.anoInicio===anoAq);
    if(p){
      // Se estiver editando, atualiza o primeiro gozo; senão adiciona
      if(p.gozados.length>0&&editingId){
        p.gozados[0]={...p.gozados[0],ini:iniV||p.gozados[0].ini,fim:fimV||p.gozados[0].fim,dias:diasAq,status,obs};
      } else {
        p.gozados.push({p:p.gozados.length+1,ini:iniV,fim:fimV,dias:diasAq,status,obs,extraOficial:false,vende:false,rescisao:false});
      }
      ensureSaldo(p);
    }
  }
  if(session.role==='diretoria'){e.oficial=document.getElementById('mOficial').checked;e.obsDir=document.getElementById('mObsDir').value;}
  closeModal();refreshPage();toast(`✓ ${e.name.split(' ')[0]} atualizado`);
}

function delRecord(){
  if(!editingId)return;
  const e=employees.find(x=>x.id===editingId);if(!e)return;
  if(!confirm(`Excluir registro de ${e.name}?`))return;
  e.periodos.forEach(p=>{p.gozados=[];ensureSaldo(p);});
  closeModal();refreshPage();toast('Registro removido');
}

function refreshPage(){
  if(currentEmpresa)renderEmpresa(currentEmpresa);
  else if(currentPage==='overview')renderOverview();
  else if(currentPage==='aquisitivos')renderAquisitivos();
  else if(currentPage==='diretoria')renderDiretoria();
  else if(currentPage==='financeiro')renderFinanceiro();
}
function onSearch(){if(currentEmpresa)renderEmpTable(currentEmpresa);else if(currentPage==='aquisitivos')renderAquisitivos();}

function exportCSV(){
  const empList=getEmps(),rows=[['Empresa','Nome','Cargo','Admissão','Período Aquisitivo','Data Limite','Data Início','Data Fim','Dias','Status','Saldo Restante','Extra-oficial','Observação']];
  employees.filter(e=>empList.includes(e.empresa)).forEach(e=>{
    e.periodos.forEach(p=>{
      ensureSaldo(p);
      p.gozados.forEach(g=>{
        rows.push([COS[e.empresa].name,e.name,e.cargo,e.admissao,p.label,p.dataLimite||'',g.ini||'',g.fim||'',g.dias,g.status,p.saldo,g.extraOficial?'Sim':'Não',g.obs||'']);
      });
    });
  });
  const csv=rows.map(r=>r.map(v=>`"${v}"`).join(',')).join('\n');
  const blob=new Blob(['\uFEFF'+csv],{type:'text/csv;charset=utf-8;'});
  const url=URL.createObjectURL(blob);
  const a=document.createElement('a');a.href=url;a.download='ferias-grupo-2026.csv';a.click();
  URL.revokeObjectURL(url);toast('✓ CSV exportado');
}
